# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# --- Database ---
DATABASE_URL=postgresql://klypup:klypup@localhost:5432/klypup

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme-generate-a-real-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Anthropic Claude API ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Google Gemini API ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- LLM provider selection (litellm-orchestrator branch) ---
# Which model app/agents/orchestrator.py calls, via litellm, expressed as
# "<provider>/<model>" split into two vars so switching providers is a .env
# edit, not a code change. Examples: LLM_PROVIDER=anthropic + LLM_MODEL=
# claude-opus-4-8, or LLM_PROVIDER=gemini + LLM_MODEL=gemini-flash-latest.
# Dated Gemini aliases (e.g. gemini-2.5-flash) can get gated/deprecated for
# a given API key even while still listed by the models API — prefer the
# "-latest" alias, which Google keeps pointed at their current recommended
# flash model.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8

# --- Alpha Vantage (market data) ---
# Free key, instant: https://www.alphavantage.co/support/#api-key
# Free tier limit: 25 requests/day, 5/minute — this is why we cache.
ALPHA_VANTAGE_API_KEY=

# --- NewsAPI (news + sentiment source data) ---
# Free key: https://newsapi.org/register
# Free "Developer" tier: articles delayed ~24h, non-commercial use only.
NEWS_API_KEY=

# --- RAG / Vector store ---
CHROMA_PERSIST_DIR=./chroma_data
