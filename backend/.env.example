# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# --- Database ---
DATABASE_URL=postgresql://klypup:klypup@localhost:5432/klypup

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme-generate-a-real-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Anthropic Claude API ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Alpha Vantage (market data) ---
# Free key, instant: https://www.alphavantage.co/support/#api-key
# Free tier limit: 25 requests/day, 5/minute — this is why we cache.
ALPHA_VANTAGE_API_KEY=

# --- NewsAPI (news + sentiment source data) ---
# Free key: https://newsapi.org/register
# Free "Developer" tier: articles delayed ~24h, non-commercial use only.
NEWS_API_KEY=

# --- RAG / Vector store ---
CHROMA_PERSIST_DIR=./chroma_data
